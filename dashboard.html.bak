<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard — HedgePick</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#050608;--s1:#0C0D10;--s2:#111318;
  --b1:rgba(255,255,255,0.07);--b2:rgba(255,255,255,0.12);
  --t1:#ECEAE4;--t2:rgba(236,234,228,0.65);--t3:rgba(236,234,228,0.35);
  --blue:#4F8EF7;--gold:#E8A930;--green:#22C55E;--red:#F87171;--amber:#FBBF24;
}
body{font-family:'Space Grotesk',sans-serif;background:var(--bg);color:var(--t1);-webkit-font-smoothing:antialiased;min-height:100vh}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 32px;background:rgba(5,6,8,0.95);backdrop-filter:blur(24px);border-bottom:1px solid var(--b1);z-index:100}
.logo{font-family:'Space Mono',monospace;font-size:14px;font-weight:700;color:var(--t1);text-decoration:none}
.logo em{color:var(--blue);font-style:normal}
.nav-r{display:flex;align-items:center;gap:16px}
.plan-badge{font-family:'Space Mono',monospace;font-size:10px;font-weight:700;padding:4px 10px;border-radius:100px;letter-spacing:.08em;text-transform:uppercase}
.plan-free{background:rgba(255,255,255,0.06);color:var(--t3)}
.plan-pro{background:rgba(79,142,247,0.12);color:var(--blue);border:1px solid rgba(79,142,247,0.2)}
.plan-life{background:rgba(232,169,48,0.1);color:var(--gold);border:1px solid rgba(232,169,48,0.2)}
.nav-email{font-size:12px;color:var(--t3)}
.logout{font-size:12px;color:var(--t3);background:none;border:none;cursor:pointer;font-family:'Space Grotesk',sans-serif;transition:color .2s}
.logout:hover{color:var(--t1)}

/* LAYOUT */
.main{padding:80px 32px 48px;max-width:860px;margin:0 auto}

/* HEADER */
.dash-header{margin-bottom:32px}
.dash-title{font-family:'Space Mono',monospace;font-size:22px;font-weight:700;color:var(--t1);margin-bottom:6px}
.dash-sub{font-size:14px;color:var(--t2);font-weight:300}

/* USAGE BAR */
.usage-card{background:var(--s1);border:1px solid var(--b1);border-radius:12px;padding:20px 24px;margin-bottom:28px;display:flex;align-items:center;justify-content:space-between;gap:24px}
.usage-left{}
.usage-label{font-size:11px;font-family:'Space Mono',monospace;text-transform:uppercase;letter-spacing:.1em;color:var(--t3);margin-bottom:8px}
.usage-bar-wrap{width:280px;height:4px;background:var(--b1);border-radius:2px;overflow:hidden}
.usage-bar-fill{height:100%;border-radius:2px;background:var(--blue);transition:width .4s ease}
.usage-count{font-size:13px;color:var(--t2);margin-top:6px}
.usage-count span{color:var(--t1);font-weight:500}
.upgrade-btn{background:var(--blue);color:#fff;border:none;border-radius:8px;padding:10px 20px;font-size:13px;font-weight:500;cursor:pointer;font-family:'Space Grotesk',sans-serif;white-space:nowrap;text-decoration:none;transition:opacity .2s}
.upgrade-btn:hover{opacity:.85}

/* TICKER INPUT SECTION */
.section-label{font-size:11px;font-family:'Space Mono',monospace;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);margin-bottom:16px}
.ticker-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
.ticker-wrap{position:relative}
.ticker-num{position:absolute;left:14px;top:50%;transform:translateY(-50%);font-family:'Space Mono',monospace;font-size:11px;color:var(--t3);pointer-events:none}
.ticker-in{width:100%;background:var(--s1);border:1px solid var(--b2);border-radius:8px;padding:14px 14px 14px 40px;color:var(--t1);font-size:14px;font-family:'Space Mono',monospace;letter-spacing:.06em;text-transform:uppercase;outline:none;transition:border .2s}
.ticker-in::placeholder{color:var(--t3);font-size:12px;letter-spacing:.04em;text-transform:none;font-family:'Space Grotesk',sans-serif}
.ticker-in:focus{border-color:rgba(79,142,247,.5)}
.ticker-in:disabled{opacity:.35;cursor:not-allowed}
.autocomplete-list{position:absolute;top:100%;left:0;right:0;background:var(--s2);border:1px solid var(--b2);border-radius:8px;margin-top:4px;z-index:50;overflow:hidden;display:none}
.ac-item{padding:10px 14px;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:10px;transition:background .15s}
.ac-item:hover{background:rgba(255,255,255,0.04)}
.ac-sym{font-family:'Space Mono',monospace;font-size:13px;font-weight:700;color:var(--t1);min-width:60px}
.ac-name{font-size:12px;color:var(--t3)}

/* SUBMIT */
.submit-row{display:flex;gap:12px;align-items:center}
.analyze-btn{background:var(--t1);color:var(--bg);border:none;border-radius:8px;padding:14px 32px;font-size:14px;font-weight:600;cursor:pointer;font-family:'Space Grotesk',sans-serif;transition:all .2s;letter-spacing:.01em}
.analyze-btn:hover{opacity:.88;transform:translateY(-1px)}
.analyze-btn:disabled{opacity:.4;cursor:not-allowed;transform:none}
.submit-note{font-size:12px;color:var(--t3)}

/* LOADING STATE */
.loading-card{display:none;background:var(--s1);border:1px solid var(--b1);border-radius:12px;padding:32px;text-align:center;margin-top:24px}
.loading-spinner{width:32px;height:32px;border:2px solid var(--b2);border-top-color:var(--blue);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 16px}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-title{font-size:15px;font-weight:500;color:var(--t1);margin-bottom:8px}
.loading-sub{font-size:13px;color:var(--t3);font-weight:300}
.loading-agents{display:flex;flex-direction:column;gap:6px;margin-top:20px;text-align:left;max-width:320px;margin-left:auto;margin-right:auto}
.agent-line{font-size:12px;color:var(--t3);display:flex;align-items:center;gap:8px;font-family:'Space Mono',monospace}
.agent-line.active{color:var(--blue)}
.agent-line.done{color:var(--green)}
.a-dot{width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0}

/* HISTORY */
.history-section{margin-top:40px}
.history-empty{background:var(--s1);border:1px solid var(--b1);border-radius:12px;padding:40px;text-align:center}
.history-empty-title{font-size:15px;font-weight:500;color:var(--t2);margin-bottom:8px}
.history-empty-sub{font-size:13px;color:var(--t3);font-weight:300}
.history-list{display:flex;flex-direction:column;gap:8px}
.history-item{background:var(--s1);border:1px solid var(--b1);border-radius:10px;padding:16px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;cursor:pointer;transition:border-color .2s}
.history-item:hover{border-color:var(--b2)}
.hi-left{display:flex;align-items:center;gap:12px}
.hi-ticker{font-family:'Space Mono',monospace;font-size:15px;font-weight:700;color:var(--t1)}
.hi-date{font-size:12px;color:var(--t3)}
.hi-signal{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;padding:3px 10px;border-radius:4px}
.sig-buy{background:rgba(34,197,94,.1);color:var(--green)}
.sig-sell{background:rgba(248,113,113,.1);color:var(--red)}
.sig-hold{background:rgba(255,255,255,.06);color:var(--t3)}
.hi-download{font-size:12px;color:var(--blue);text-decoration:none;white-space:nowrap}

/* UPGRADE BANNER */
.upgrade-banner{background:linear-gradient(135deg,rgba(79,142,247,0.08),rgba(232,169,48,0.06));border:1px solid rgba(79,142,247,0.2);border-radius:12px;padding:24px;margin-top:32px;display:flex;align-items:center;justify-content:space-between;gap:20px}
.ub-text{}
.ub-title{font-size:15px;font-weight:500;color:var(--t1);margin-bottom:4px}
.ub-sub{font-size:13px;color:var(--t2);font-weight:300}

@media(max-width:640px){
  .ticker-grid{grid-template-columns:1fr}
  .main{padding:80px 16px 48px}
  nav{padding:0 16px}
  .usage-card{flex-direction:column;align-items:flex-start}
  .upgrade-banner{flex-direction:column}
}
</style>
<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-W2VWCNQC6T"></script>
<script>
window.dataLayer=window.dataLayer||[];
function gtag(){dataLayer.push(arguments);}
gtag('js',new Date());
gtag('config','G-W2VWCNQC6T');
</script>
</head>
<body>

<nav>
  <a href="/" class="logo">HEDGE<em>PICK</em></a>
  <div class="nav-r">
    <span class="plan-badge plan-free" id="planBadge">Free</span>
    <span class="nav-email" id="userEmail">user@example.com</span>
    <button class="logout" onclick="logout()">Sign out</button>
  </div>
</nav>

<div class="main">

  <!-- New user welcome (shown after Stripe redirect) -->
  <div id="dashWelcome" style="display:none;background:linear-gradient(135deg,rgba(34,197,94,0.06),rgba(79,142,247,0.04));border:1px solid rgba(34,197,94,0.15);border-radius:12px;padding:18px 24px;margin-bottom:20px;display:none;align-items:center;gap:16px">
    <div style="font-size:24px">🎉</div>
    <div>
      <div style="font-size:15px;font-weight:500;color:#ECEAE4;margin-bottom:3px">Welcome to HedgePick!</div>
      <div style="font-size:13px;color:rgba(236,234,228,0.6);font-weight:300">Your account is active. Enter a ticker below to run your first analysis.</div>
    </div>
  </div>

  <!-- Header -->
  <div class="dash-header">
    <div class="dash-title">Your dashboard</div>
    <div class="dash-sub">Enter up to <span id="maxTickers">1</span> ticker to analyze. Reports are emailed to you within minutes.</div>
  </div>

  <!-- Usage bar -->
  <div class="usage-card">
    <div class="usage-left">
      <div class="usage-label">Daily analyses</div>
      <div class="usage-bar-wrap"><div class="usage-bar-fill" id="usageBar" style="width:0%"></div></div>
      <div class="usage-count"><span id="usageUsed">0</span> of <span id="usageMax">1</span> used today</div>
      <div class="usage-upgrade-nudge" id="usageNudge" onclick="openUpgradeModal('nudge')">Get 5 analyses/day — from $19 →</div>
    </div>
    <button onclick="openUpgradeModal('usage')" class="upgrade-btn" id="upgradeBtn" type="button">Upgrade now →</button>
  </div>

  <!-- Ticker inputs -->
  <div class="section-label">Enter tickers</div>
  <div class="ticker-grid" id="tickerGrid">
    <div class="ticker-wrap">
      <span class="ticker-num">1</span>
      <input class="ticker-in" type="text" placeholder="e.g. NVDA, AAPL, IONQ..." id="t1" maxlength="8" autocomplete="off" oninput="autocomplete(this,'ac1')" onkeydown="acKey(event,'ac1')">
      <div class="autocomplete-list" id="ac1"></div>
    </div>
    <div class="ticker-wrap" id="tw2" style="display:none">
      <span class="ticker-num">2</span>
      <input class="ticker-in" type="text" placeholder="Ticker 2..." id="t2" maxlength="8" autocomplete="off" oninput="autocomplete(this,'ac2')" onkeydown="acKey(event,'ac2')">
      <div class="autocomplete-list" id="ac2"></div>
    </div>
    <div class="ticker-wrap" id="tw3" style="display:none">
      <span class="ticker-num">3</span>
      <input class="ticker-in" type="text" placeholder="Ticker 3..." id="t3" maxlength="8" autocomplete="off" oninput="autocomplete(this,'ac3')" onkeydown="acKey(event,'ac3')">
      <div class="autocomplete-list" id="ac3"></div>
    </div>
    <div class="ticker-wrap" id="tw4" style="display:none">
      <span class="ticker-num">4</span>
      <input class="ticker-in" type="text" placeholder="Ticker 4..." id="t4" maxlength="8" autocomplete="off" oninput="autocomplete(this,'ac4')" onkeydown="acKey(event,'ac4')">
      <div class="autocomplete-list" id="ac4"></div>
    </div>
    <div class="ticker-wrap" id="tw5" style="display:none">
      <span class="ticker-num">5</span>
      <input class="ticker-in" type="text" placeholder="Ticker 5..." id="t5" maxlength="8" autocomplete="off" oninput="autocomplete(this,'ac5')" onkeydown="acKey(event,'ac5')">
      <div class="autocomplete-list" id="ac5"></div>
    </div>
  </div>

  <div class="submit-row">
    <button class="analyze-btn" id="analyzeBtn" onclick="submitAnalysis()">Generate report →</button>
    <span class="submit-note" id="submitNote">Reports are emailed within 5 minutes &mdash; you can close this window</span>
  </div>

  <!-- Loading state -->
  <div class="loading-card" id="loadingCard">
    <div class="loading-spinner"></div>
    <div class="loading-title">Analysis submitted</div>
    <div class="loading-sub" style="margin-bottom:16px">Your 9-agent AI analysis is running. This takes <strong>3&ndash;5 minutes</strong> per ticker.</div>
    <div style="background:rgba(34,197,94,0.06);border:1px solid rgba(34,197,94,0.15);border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:rgba(236,234,228,0.7);display:flex;align-items:center;gap:10px">
      <span style="color:#22C55E;font-size:16px">&#9993;</span>
      <span>Your report will be emailed to <strong id="loadingEmail">your inbox</strong>. <strong>You can close this window</strong> &mdash; we&rsquo;ll send it when it&rsquo;s ready.</span>
    </div>
    <div class="loading-agents" id="agentList"></div>
  </div>

  <!-- Report history -->
  <div class="history-section">
    <div class="section-label" style="margin-top:0">Report history</div>
    <div id="historyContainer">
      <div class="history-empty">
        <div class="history-empty-title">No reports yet</div>
        <div class="history-empty-sub">Your analysis reports will appear here after you run your first analysis.</div>
      </div>
    </div>
  </div>

  <!-- Soft upgrade nudge (free users only) -->
  <div class="upgrade-banner" id="upgradeBanner" style="background:var(--s1);border:1px solid var(--b1);border-radius:12px;padding:20px 24px;margin-top:32px;display:flex;align-items:center;justify-content:space-between;gap:20px">
    <div style="display:flex;align-items:center;gap:14px">
      <div style="width:36px;height:36px;border-radius:8px;background:rgba(232,169,48,0.1);border:1px solid rgba(232,169,48,0.2);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">⚡</div>
      <div>
        <div style="font-size:14px;font-weight:500;color:var(--t1);margin-bottom:3px">You're on the free plan</div>
        <div style="font-size:12px;color:var(--t2);font-weight:300">Unlock 5 analyses per day, full agent reasoning, and stop loss guidance.</div>
      </div>
    </div>
    <button onclick="openUpgradeModal('nudge')" style="background:transparent;border:1px solid var(--b2);border-radius:8px;padding:9px 18px;font-size:13px;font-weight:500;color:var(--t1);cursor:pointer;font-family:'Space Grotesk',sans-serif;white-space:nowrap;transition:all .2s">See plans →</button>
  </div>

</div>

<script>
// ── Backend URL ──────────────────────────────────────────────
const BACKEND = 'https://web-production-45241.up.railway.app';

// ── Ticker autocomplete data ────────────────────────────────
const TICKERS = [
  {s:'AAPL',n:'Apple Inc.'},
  {s:'MSFT',n:'Microsoft Corporation'},
  {s:'NVDA',n:'Nvidia Corporation'},
  {s:'GOOGL',n:'Alphabet Inc.'},
  {s:'AMZN',n:'Amazon.com Inc.'},
  {s:'META',n:'Meta Platforms Inc.'},
  {s:'TSLA',n:'Tesla Inc.'},
  {s:'IONQ',n:'IonQ Inc.'},
  {s:'RGTI',n:'Rigetti Computing Inc.'},
  {s:'QUBT',n:'Quantum Computing Inc.'},
  {s:'QBTS',n:'D-Wave Quantum Inc.'},
  {s:'ARQQ',n:'Arqit Quantum Inc.'},
  {s:'IBM',n:'IBM Corporation'},
  {s:'IESC',n:'IES Holdings Inc.'},
  {s:'CEG',n:'Constellation Energy Corporation'},
  {s:'VRT',n:'Vertiv Holdings Co.'},
  {s:'ASTS',n:'AST SpaceMobile Inc.'},
  {s:'XOM',n:'Exxon Mobil Corporation'},
  {s:'CVX',n:'Chevron Corporation'},
  {s:'COP',n:'ConocoPhillips'},
  {s:'MU',n:'Micron Technology Inc.'},
  {s:'ANET',n:'Arista Networks Inc.'},
  {s:'AMD',n:'Advanced Micro Devices Inc.'},
  {s:'INTC',n:'Intel Corporation'},
  {s:'JPM',n:'JPMorgan Chase & Co.'},
  {s:'GS',n:'Goldman Sachs Group Inc.'},
  {s:'BA',n:'Boeing Company'},
  {s:'LMT',n:'Lockheed Martin Corporation'},
  {s:'NOC',n:'Northrop Grumman Corporation'},
  {s:'RTX',n:'RTX Corporation'},
  {s:'PLTR',n:'Palantir Technologies Inc.'},
  {s:'SNOW',n:'Snowflake Inc.'},
  {s:'DDOG',n:'Datadog Inc.'},
  {s:'CRWD',n:'CrowdStrike Holdings Inc.'},
  {s:'UBER',n:'Uber Technologies Inc.'},
  {s:'COIN',n:'Coinbase Global Inc.'},
  {s:'SOFI',n:'SoFi Technologies Inc.'},
  {s:'MP',n:'MP Materials Corp.'},
  {s:'BE',n:'Bloom Energy Corporation'},
  {s:'FSLR',n:'First Solar Inc.'},
];

// ── Plan config ─────────────────────────────────────────────
const PLAN = {
  tier: 'free', // free | pro | lifetime
  used: 0,
  max: 1,
  email: 'user@example.com'
};

function initDashboard() {
  // In production this comes from your backend session
  // For now simulate based on URL params
  const params = new URLSearchParams(window.location.search);
  const tier = params.get('tier') || 'free';
  const email = params.get('email') || '';
  
  PLAN.tier = tier;
  PLAN.max = tier === 'free' ? 1 : 5;
  if(email) PLAN.email = email;

  // Update UI
  document.getElementById('userEmail').textContent = PLAN.email;
  document.getElementById('usageMax').textContent = PLAN.max;
  document.getElementById('maxTickers').textContent = PLAN.max;

  const badge = document.getElementById('planBadge');
  if(tier === 'pro') { badge.className='plan-badge plan-pro'; badge.textContent='Pro'; }
  else if(tier === 'lifetime') { badge.className='plan-badge plan-life'; badge.textContent='Lifetime'; }

  // Show extra ticker inputs for paid users
  for(let i=2; i<=PLAN.max; i++) {
    const tw = document.getElementById('tw'+i);
    if(tw) tw.style.display='block';
  }

  // Hide upgrade elements for paid users
  if(tier !== 'free') {
    const ub = document.getElementById('upgradeBanner');
    if(ub) ub.style.display='none';
    const btn = document.getElementById('upgradeBtn');
    if(btn) btn.style.display='none';
  }

  // Update usage bar
  updateUsage(0);

  // Load history
  loadHistory();
}

function updateUsage(used) {
  PLAN.used = used;
  document.getElementById('usageUsed').textContent = used;
  if(PLAN.tier === 'free' && used >= 1 && PLAN.max <= 1) {
    document.getElementById('usageNudge').classList.add('show');
  }
  const pct = Math.min((used/PLAN.max)*100, 100);
  document.getElementById('usageBar').style.width = pct + '%';
  if(pct >= 100) {
    document.getElementById('usageBar').style.background = 'var(--amber)';
    document.getElementById('analyzeBtn').disabled = true;
    document.getElementById('submitNote').textContent = 'Daily limit reached. Resets at midnight.';
  }
}

// ── Autocomplete ─────────────────────────────────────────────
function autocomplete(input, listId) {
  const val = input.value.toUpperCase().trim();
  const list = document.getElementById(listId);
  if(!val || val.length < 1) { list.style.display='none'; return; }
  
  const matches = TICKERS.filter(t => 
    t.s.startsWith(val) || t.n.toUpperCase().includes(val)
  ).slice(0,6);
  
  if(!matches.length) { list.style.display='none'; return; }
  
  list.innerHTML = matches.map(t => 
    `<div class="ac-item" onclick="selectTicker('${t.s}','${listId}',this)">
      <span class="ac-sym">${t.s}</span>
      <span class="ac-name">${t.n}</span>
    </div>`
  ).join('');
  list.style.display = 'block';
}

function selectTicker(sym, listId, el) {
  const list = document.getElementById(listId);
  const inputId = 't' + listId.replace('ac','');
  document.getElementById(inputId).value = sym;
  list.style.display = 'none';
}

function acKey(e, listId) {
  if(e.key === 'Escape') document.getElementById(listId).style.display='none';
}

// Close autocomplete on outside click
document.addEventListener('click', e => {
  document.querySelectorAll('.autocomplete-list').forEach(l => {
    if(!l.contains(e.target)) l.style.display='none';
  });
});

// ── Submit analysis ──────────────────────────────────────────
function submitAnalysis() {
  const tickers = [];
  for(let i=1; i<=PLAN.max; i++) {
    const val = document.getElementById('t'+i)?.value?.trim().toUpperCase();
    if(val) tickers.push(val);
  }
  
  if(!tickers.length) {
    alert('Please enter at least one ticker symbol.');
    return;
  }

  if(PLAN.used >= PLAN.max) {
    alert('Daily limit reached. Upgrade to Pro for more analyses.');
    return;
  }

  // Show loading state
  document.getElementById('loadingCard').style.display='block';
  var le = document.getElementById('loadingEmail');
  if(le) le.textContent = PLAN.email || 'your inbox';
  document.getElementById('analyzeBtn').disabled = true;
  document.getElementById('submitNote').textContent = 'Analysis running...';

  // Animate agents
  const agents = [
    'Fundamentals analyst','Sentiment analyst','News analyst',
    'Technical analyst','Bull researcher','Bear researcher',
    'Trader agent','Risk manager','Portfolio manager'
  ];
  const agentList = document.getElementById('agentList');
  agentList.innerHTML = agents.map((a,i) => 
    `<div class="agent-line" id="ag${i}"><span class="a-dot"></span>${a}</div>`
  ).join('');

  let i = 0;
  const interval = setInterval(() => {
    if(i > 0) document.getElementById('ag'+(i-1))?.classList.replace('active','done');
    if(i < agents.length) {
      document.getElementById('ag'+i)?.classList.add('active');
      i++;
    } else {
      clearInterval(interval);
      // In production: POST to your backend here
      // For now show success message
      setTimeout(() => {
        document.getElementById('loadingCard').innerHTML = `
          <div style="font-size:40px;margin-bottom:16px">⚡</div>
          <div class="loading-title" style="margin-bottom:8px">Analysis queued!</div>
          <div class="loading-sub" style="margin-bottom:16px">Your <strong>${tickers.join(', ')}</strong> analysis is running now. The full PDF report will be emailed to <strong>${PLAN.email}</strong> within 5 minutes.</div>
          <div style="background:rgba(34,197,94,0.06);border:1px solid rgba(34,197,94,0.15);border-radius:8px;padding:12px 16px;font-size:13px;color:rgba(236,234,228,0.65);line-height:1.6">
            You can close this window &mdash; we&rsquo;ll send the report when it&rsquo;s ready. Check spam if you don&rsquo;t see it.
          </div>
        `;
        updateUsage(PLAN.used + tickers.length);
        addToHistory(tickers);
      }, 800);
    }
  }, 400);

  // POST to Flask backend
  fetch(BACKEND + '/api/analyze', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({tickers, email: PLAN.email})
  }).then(r => r.json()).then(data => {
    console.log('Analysis queued:', data);
  }).catch(err => console.error('Backend error:', err));
}

// ── History ──────────────────────────────────────────────────
function loadHistory() {
  const history = JSON.parse(localStorage.getItem('hp_history') || '[]');
  renderHistory(history);
}

function addToHistory(tickers) {
  const history = JSON.parse(localStorage.getItem('hp_history') || '[]');
  tickers.forEach(t => {
    history.unshift({
      ticker: t,
      date: new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),
      signal: ['BUY','SELL','HOLD'][Math.floor(Math.random()*3)],
      id: Date.now()
    });
  });
  localStorage.setItem('hp_history', JSON.stringify(history.slice(0,50)));
  renderHistory(history);
}

function renderHistory(history) {
  const container = document.getElementById('historyContainer');
  if(!history.length) {
    container.innerHTML = `
      <div class="history-empty">
        <div class="history-empty-title">No reports yet</div>
        <div class="history-empty-sub">Your analysis reports will appear here after you run your first analysis.</div>
      </div>`;
    return;
  }
  container.innerHTML = `<div class="history-list">${history.slice(0,10).map(h => {
    const isPending = h.signal === 'pending';
    const sigClass  = isPending ? 'sig-hold' : 'sig-' + h.signal.toLowerCase();
    const sigLabel  = isPending ? 'Processing...' : h.signal;
    return `
    <div class="history-item">
      <div class="hi-left">
        <span class="hi-ticker">${h.ticker}</span>
        <span class="hi-date">${h.date}</span>
      </div>
      <div style="display:flex;align-items:center;gap:16px">
        <span class="hi-signal ${sigClass}">${sigLabel}</span>
        ${isPending
          ? '<span style="font-size:12px;color:var(--t3)">Report emailing...</span>'
          : '<a href="#" class="hi-download">Download PDF</a>'
        }
      </div>
    </div>`;
  }).join('')}</div>`;
}

function logout() {
  window.location.href = '/';
}

function requestMagicLink(email) {
  return fetch(BACKEND + '/api/magic-link', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({email})
  }).then(r => r.json());
}

initDashboard();

// ── UPGRADE MODAL ────────────────────────────────────────────
const modalMessages = {
  usage:{eyebrow:'Upgrade your plan',title:'See why, deeper.',sub:"Free users see the verdict. Paid users see the full debate — every agent's reasoning, bull/bear confrontation, stop loss levels, and position sizing."},
  nudge:{eyebrow:'Upgrade your plan',title:'The full picture costs less than you think.',sub:'$49 one-time. No subscription. Lifetime access to everything — 5 analyses per day, full agent reasoning, bull/bear debate, stop loss, position sizing.'}
};
function openUpgradeModal(source){
  var msg=modalMessages[source]||modalMessages.usage;
  document.getElementById('modalEyebrow').textContent=msg.eyebrow;
  document.getElementById('modalTitle').textContent=msg.title;
  document.getElementById('modalSub').textContent=msg.sub;
  document.getElementById('upgradeModal').style.display='flex';
  document.body.style.overflow='hidden';
}
function closeUpgradeModal(){
  document.getElementById('upgradeModal').style.display='none';
  document.body.style.overflow='';
}
function closeModalOutside(e){
  if(e.target===document.getElementById('upgradeModal'))closeUpgradeModal();
}
document.addEventListener('keydown',function(e){if(e.key==='Escape')closeUpgradeModal();});

// ── SIGN IN GATE ─────────────────────────────────────────────
function openSignInGate(){
  document.getElementById('signinGate').style.display='flex';
  document.body.style.overflow='hidden';
}
function closeSignInGate(){
  document.getElementById('signinGate').style.display='none';
  document.body.style.overflow='';
}
function submitSignIn(){
  var email=document.getElementById('gateEmail').value.trim().toLowerCase();
  if(!email||!email.includes('@')){alert('Please enter a valid email address.');return;}
  // Go straight to dashboard with email
  window.location.href='/dashboard?email='+encodeURIComponent(email)+'&tier=free';
}
document.addEventListener('DOMContentLoaded',function(){
  var params=new URLSearchParams(window.location.search);
  var email = params.get('email');
  var tier  = params.get('tier');
  var fresh = params.get('new'); // Stripe redirects with ?new=1

  if(email){
    // Coming from Stripe or magic link - already authenticated
    PLAN.email = email;
    document.getElementById('userEmail').textContent = email;
    if(tier){ 
      PLAN.tier = tier;
      PLAN.max  = tier === 'free' ? 1 : 5;
      var badge = document.getElementById('planBadge');
      if(tier==='pro'){badge.className='plan-badge plan-pro';badge.textContent='Pro';}
      else if(tier==='lifetime'){badge.className='plan-badge plan-life';badge.textContent='Lifetime';}
    }
    // Show welcome message for brand new users
    if(fresh==='1'){
      document.getElementById('dashWelcome').style.display='block';
    }
  } else {
    // No email - show sign in gate
    setTimeout(openSignInGate, 300);
  }
  // Fetch real usage from Railway
  if(PLAN.email && PLAN.email !== 'user@example.com') {
    fetch(BACKEND + '/api/user?email=' + encodeURIComponent(PLAN.email))
      .then(r => r.json())
      .then(data => {
        if(data.analyses_today !== undefined) {
          updateUsage(data.analyses_today);
        } else {
          updateUsage(0);
        }
        if(data.tier) {
          PLAN.tier = data.tier;
          PLAN.max  = data.daily_limit || 1;
          document.getElementById('usageMax').textContent = PLAN.max;
          document.getElementById('maxTickers').textContent = PLAN.max;
          var badge = document.getElementById('planBadge');
          if(data.tier==='pro'){badge.className='plan-badge plan-pro';badge.textContent='Pro';}
          else if(data.tier==='lifetime'){badge.className='plan-badge plan-life';badge.textContent='Lifetime';}
          // Show/hide extra ticker inputs
          for(var i=2; i<=PLAN.max; i++){
            var tw = document.getElementById('tw'+i);
            if(tw) tw.style.display='block';
          }
          // Hide upgrade for paid
          if(data.tier !== 'free'){
            var ub=document.getElementById('upgradeBanner');
            if(ub) ub.style.display='none';
            var btn=document.getElementById('upgradeBtn');
            if(btn) btn.style.display='none';
          }
        }
      })
      .catch(function(){ updateUsage(0); });
  } else {
    updateUsage(0);
  }
  loadHistory();
});

</script>


